# VPS .env (not used at runtime — baked into image at CI build)
DOCKERHUB_USERNAME=your-dockerhub-username

# GitHub Actions variable: NEXT_PUBLIC_API_URL (inlined at docker build in CI)
NEXT_PUBLIC_API_URL=http://localhost:5000

# Root domain for portfolio subdomain Host parsing and canonical public URLs
# (no protocol). Local: localhost:3000 — visit alice.localhost:3000
# Prod example: oboxsteam.website — visit alice.oboxsteam.website
NEXT_PUBLIC_ROOT_DOMAIN=localhost:3000
