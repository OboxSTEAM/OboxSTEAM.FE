{
  "mcpServers": {
    "shadcn": {
      "command": "npx",
      "args": [
        "shadcn@latest",
        "mcp"
      ]
    },
    "console-ninja": {
      "command": "node",
      "args": [
        "~/.console-ninja/mcp/"
      ]
    },
    "obox-api": {
      "command": "npx",
      "args": [
        "-y",
        "@reapi/mcp-openapi@latest",
        "--dir",
        "./specs"
      ]
    }
  }
}